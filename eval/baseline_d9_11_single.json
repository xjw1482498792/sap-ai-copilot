      "id": "D9-11",
      "difficulty": "L5",
      "question": "今年每月销售额的环比增长率",
      "sql": "WITH monthly_sales AS (\n  SELECT\n    STRFTIME('%Y-%m', VBAK.ERDAT) AS month,\n    SUM(VBAK.NETWR) AS sales_amount\n  FROM VBAK\n  WHERE VBAK.ERDAT >= '2026-01-01'\n    AND VBAK.ERDAT < '2027-01-01'\n  GROUP BY STRFTIME('%Y-%m', VBAK.ERDAT)\n)\nSELECT\n  month,\n  sales_amount,\n  LAG(sales_amount) OVER (ORDER BY month) AS prev_month_sales,\n  CASE\n    WHEN LAG(sales_amount) OVER (ORDER BY month) IS NULL OR LAG(sales_amount) OVER (ORDER BY month) = 0 THEN NULL\n    ELSE ROUND((sales_amount - LAG(sales_amount) OVER (ORDER BY month)) / LAG(sales_amount) OVER (ORDER BY month) * 100, 2)\n  END AS growth_rate_pct\nFROM monthly_sales\nORDER BY month",
