      "difficulty": "L5",
      "question": "今年每月销售额的环比增长率",
      "sql": "WITH monthly_sales AS (\n  SELECT\n    STRFTIME('%Y-%m', ERDAT) AS month,\n    SUM(NETWR) AS sales_amount\n  FROM VBAK\n  WHERE ERDAT >= '2026-01-01'\n    AND ERDAT < '2027-01-01'\n  GROUP BY STRFTIME('%Y-%m', ERDAT)\n)\nSELECT\n  month,\n  sales_amount,\n  CASE\n    WHEN LAG(sales_amount) OVER (ORDER BY month) IS NULL THEN NULL\n    ELSE ROUND((sales_amount - LAG(sales_amount) OVER (ORDER BY month)) / LAG(sales_amount) OVER (ORDER BY month) * 100, 2)\n  END AS growth_rate_pct\nFROM monthly_sales\nORDER BY month",
